<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented alcoholic beverage made from grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A feature or attribute of a wine, such as color, flavor, or region.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWineColor">
  <rdfs:comment xml:lang="en">The characteristic of being red in color, typically associated with red wines.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine Color</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWineColor">
  <rdfs:comment xml:lang="en">The characteristic of being white in color, typically associated with white wines.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine Color</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BordeauxWine">
  <rdfs:comment xml:lang="en">A wine from the Bordeaux region, typically a red wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux Wine</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#hasWineCharacteristic'/>
    <owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#RedWineColor'/>
  </owl:Restriction>
</rdfs:subClassOf>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource='http://www.semanticweb.org/myontology#hasWineCharacteristic'/>
    <owl:someValuesFrom rdf:resource='http://www.semanticweb.org/myontology#BordeauxGrapes'/>
  </owl:Restriction>
</rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vintage">
  <rdfs:comment xml:lang="en">A specific vintage year of a particular wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The aroma or nose of a wine, especially as developed through aging.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The weight or fullness of a wine on the palate.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A wine region characteristic, indicating the geographic origin of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVariety">
  <rdfs:comment xml:lang="en">A characteristic specifying the grape variety from which a wine is made.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Variety</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageQuality">
  <rdfs:comment xml:lang="en">A quality rating assigned to a vintage, such as Good, Excellent, or Poor.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Quality</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CabernetSauvignon">
  <rdfs:comment xml:lang="en">The characteristic of being made from the Cabernet Sauvignon grape variety.</rdfs:comment>
  <rdfs:label xml:lang="en">Cabernet Sauvignon</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#GrapeVariety'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Merlot">
  <rdfs:comment xml:lang="en">The characteristic of being made from the Merlot grape variety.</rdfs:comment>
  <rdfs:label xml:lang="en">Merlot</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#GrapeVariety'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CabernetFranc">
  <rdfs:comment xml:lang="en">The characteristic of being made from the Cabernet Franc grape variety.</rdfs:comment>
  <rdfs:label xml:lang="en">Cabernet Franc</rdfs:label>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#GrapeVariety'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#BordeauxGrapes">
  <rdfs:comment xml:lang="en">The set of grape characteristics associated with Bordeaux wines: Cabernet Sauvignon, Merlot, and Cabernet Franc.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux Grapes</rdfs:label>
  <owl:equivalentClass>
  <owl:Class>
    <owl:unionOf rdf:parseType="Collection">
      <owl:Class rdf:about="http://www.semanticweb.org/myontology#CabernetSauvignon"/>
      <owl:Class rdf:about="http://www.semanticweb.org/myontology#Merlot"/>
      <owl:Class rdf:about="http://www.semanticweb.org/myontology#CabernetFranc"/>
    </owl:unionOf>
  </owl:Class>
</owl:equivalentClass>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasWineCharacteristic">
  <rdfs:comment xml:lang="en">Relates a wine to one of its characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has wine characteristic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintage">
  <rdfs:comment xml:lang="en">Relates a wine to one of its vintages.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#fromWine">
  <rdfs:comment xml:lang="en">Indicates the wine from which this vintage is produced.</rdfs:comment>
  <rdfs:label xml:lang="en">from wine</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasVintage'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageCharacteristic">
  <rdfs:comment xml:lang="en">Relates a vintage to one of its specific characteristics, such as bouquet or body.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage characteristic</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageQuality">
  <rdfs:comment xml:lang="en">Relates a vintage to its quality rating.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage quality</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageQuality"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#vintageYear">
  <rdfs:comment xml:lang="en">The year in which the vintage was produced.</rdfs:comment>
  <rdfs:label xml:lang="en">vintage year</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vintage"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
</owl:DatatypeProperty>

</rdf:RDF>