<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">A living organism of the kingdom Animalia.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that feeds primarily on plants.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eatsPlantPart"/>
    <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
  </owl:Restriction>
</rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">A living organism of the kingdom Plantae.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#PlantPart">
  <rdfs:comment xml:lang="en">A part of a plant, such as a leaf, root, or fruit.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant Part</rdfs:label>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Lion">
  <rdfs:comment xml:lang="en">A large carnivorous feline mammal of Africa and Asia.</rdfs:comment>
  <rdfs:label xml:lang="en">Lion</rdfs:label>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eatsPlantPart"/>
    <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxCardinality>
  </owl:Restriction>
</rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#CarnivorousPlant">
  <rdfs:comment xml:lang="en">A plant that captures and digests animals, typically insects.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivorous Plant</rdfs:label>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eatsAnimal"/>
    <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  </owl:Restriction>
</rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that feeds primarily on other animals.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
<rdfs:subClassOf>
  <owl:Restriction>
    <owl:onProperty rdf:resource="http://www.semanticweb.org/myontology#eats"/>
    <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  </owl:Restriction>
</rdfs:subClassOf>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eats">
  <rdfs:comment xml:lang="en">Indicates that one animal consumes another animal as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsPlantPart">
  <rdfs:comment xml:lang="en">Indicates that an animal consumes a specific plant part as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats plant part</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#eatsAnimal">
  <rdfs:comment xml:lang="en">Indicates that a plant captures and digests an animal as food.</rdfs:comment>
  <rdfs:label xml:lang="en">eats animal</rdfs:label>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:ObjectProperty>

</rdf:RDF>